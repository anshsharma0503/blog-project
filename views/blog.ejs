<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title><%= blog.title %> – BlogApp</title>
    <meta name="description" content="<%= blog.body.substring(0,150) %>">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-wrap">
<div class="container-md" style="padding-top:2rem;padding-bottom:4rem;">

    <!-- Cover Image -->
    <img
        class="blog-cover"
        src="<%= blog.coverImageURL %>"
        alt="<%= blog.title %>"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
    >
    <div class="blog-cover-placeholder" style="display:none;">✍️</div>

    <!-- Title -->
    <h1 class="blog-detail-title"><%= blog.title %></h1>

    <!-- Author row -->
    <div class="blog-author-row">
        <div class="avatar avatar-lg">
            <%= blog.createdBy.fullName.charAt(0).toUpperCase() %>
        </div>
        <div>
            <div class="blog-author-name"><%= blog.createdBy.fullName %></div>
            <div class="blog-date">
                <%= new Date(blog.createdAt).toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) %>
            </div>
        </div>

        <!-- Owner actions -->
        <% if(user && user._id == blog.createdBy._id){ %>
        <div class="blog-actions" style="margin-top:0;margin-left:auto;">
            <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning btn-sm">✏️ Edit</a>
            <form method="POST" action="/blog/delete/<%= blog._id %>" onsubmit="return confirm('Delete this post?');">
                <button type="submit" class="btn btn-danger btn-sm">🗑 Delete</button>
            </form>
        </div>
        <% } %>
    </div>

    <!-- Body -->
    <div class="blog-body"><%= blog.body %></div>

    <div class="divider" style="margin-top:3rem;"></div>


    <!-- ===================== COMMENTS ===================== -->
    <div class="comments-section">

        <h2 class="comments-title">
            💬 Comments
            <span style="font-size:.9rem;font-weight:400;color:var(--text-3);margin-left:.4rem;">(<%= comments.length %>)</span>
        </h2>

        <!-- Comment list -->
        <% if(comments.length === 0){ %>
        <div style="padding:2rem 0;color:var(--text-3);font-size:.9rem;">
            No comments yet. Be the first to share your thoughts!
        </div>
        <% } %>

        <% comments.forEach(function(c){ %>
        <div class="comment-card" id="comment-<%= c._id %>">

            <div class="comment-header">
                <div class="avatar" style="width:28px;height:28px;font-size:.68rem;">
                    <%= c.createdBy.fullName.charAt(0).toUpperCase() %>
                </div>
                <span class="comment-author"><%= c.createdBy.fullName %></span>
                <span class="comment-date">
                    <%= new Date(c.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
                </span>
            </div>

            <p class="comment-text" id="text-<%= c._id %>"><%= c.content %></p>

            <% if(user && user._id == c.createdBy._id){ %>
            <div class="comment-actions">

                <button class="btn btn-ghost btn-sm"
                    onclick="toggleEdit('<%= c._id %>')">
                    ✏️ Edit
                </button>

                <form method="POST" action="/comment/delete/<%= c._id %>"
                    onsubmit="return confirm('Delete comment?');" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm">🗑 Delete</button>
                </form>

            </div>

            <!-- Inline edit -->
            <form method="POST" action="/comment/edit/<%= c._id %>"
                class="inline-edit-form" id="edit-<%= c._id %>">
                <textarea name="content" class="form-control" style="min-height:80px;" required><%= c.content %></textarea>
                <div style="display:flex;gap:.5rem;">
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    <button type="button" class="btn btn-ghost btn-sm"
                        onclick="toggleEdit('<%= c._id %>')">Cancel</button>
                </div>
            </form>
            <% } %>

        </div>
        <% }); %>

        <!-- Add Comment -->
        <% if(user){ %>
        <div style="margin-top:2rem;">
            <h3 style="font-size:1rem;font-weight:600;color:var(--text-2);margin-bottom:.875rem;">Leave a comment</h3>
            <form method="POST" action="/comment/create">
                <input type="hidden" name="blogId" value="<%= blog._id %>">
                <div class="form-group">
                    <textarea name="content" class="form-control"
                        placeholder="Share your thoughts…" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Post Comment</button>
            </form>
        </div>
        <% } else { %>
        <div style="margin-top:2rem;padding:1.25rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);text-align:center;color:var(--text-2);font-size:.9rem;">
            <a href="/user/login" style="color:var(--primary);font-weight:600;">Sign in</a> to leave a comment.
        </div>
        <% } %>

    </div>

</div>
</div>

<script>
function toggleEdit(id) {
    const form = document.getElementById('edit-' + id);
    form.classList.toggle('open');
}
</script>

</body>
</html>
