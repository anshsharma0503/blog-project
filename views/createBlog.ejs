<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Write a Post – BlogApp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-wrap">
<div class="container-md" style="padding-top:2.5rem;padding-bottom:4rem;">

    <div style="margin-bottom:2rem;">
        <h1 style="font-family:'Outfit',sans-serif;font-size:1.9rem;font-weight:800;" class="text-gradient">
            Write a New Post
        </h1>
        <p style="color:var(--text-3);margin-top:.35rem;">
            Share your ideas, stories and insights with the world.
        </p>
    </div>

    <div class="form-card" style="padding:2rem;">

        <% if(error){ %>
        <div class="alert alert-error">
            ⚠️ <%= error %>
        </div>
        <% } %>

        <form method="POST" action="/blog/create" enctype="multipart/form-data" id="create-form">

            <div class="form-group">
                <label class="form-label" for="title">Post Title</label>
                <input id="title" name="title" class="form-control"
                    placeholder="Write a compelling title…" required>
            </div>

            <!-- Cover Image Upload -->
            <div class="form-group">
                <label class="form-label">Cover Image <span style="color:var(--text-3);">(optional)</span></label>
                <div class="file-upload" onclick="document.getElementById('coverImage').click()">
                    <input type="file" id="coverImage" name="coverImage"
                        accept="image/jpeg,image/png,image/gif,image/webp"
                        onchange="previewImage(this)">
                    <div class="file-upload-icon">🖼️</div>
                    <p class="file-upload-text">Click to upload cover image</p>
                    <p class="file-upload-hint">JPG, PNG, GIF or WebP — max 5MB</p>
                </div>
                <img id="img-preview" src="" alt="Preview">
            </div>

            <div class="form-group">
                <label class="form-label" for="body">Content</label>
                <textarea id="body" name="body" class="form-control"
                    style="min-height:300px;"
                    placeholder="Tell your story here…" required></textarea>
            </div>

            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <button type="submit" class="btn btn-primary btn-lg">
                    🚀 Publish Post
                </button>
                <a href="/" class="btn btn-ghost btn-lg">Cancel</a>
            </div>

        </form>

    </div>

</div>
</div>

<script>
function previewImage(input) {
    const preview = document.getElementById('img-preview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            preview.src = e.target.result;
            preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>

</body>
</html>
