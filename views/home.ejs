<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>BlogApp – Share Your Story</title>
    <meta name="description" content="A modern blogging platform. Read, write and share stories that matter.">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-wrap">
<div class="container">

    <!-- Hero -->
    <div class="hero">
        <h1 class="hero-title">Stories Worth Reading</h1>
        <p class="hero-sub">Discover ideas, thoughts and stories from writers around the world.</p>

        <% if(!user){ %>
        <div style="margin-top:1.5rem;display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;">
            <a href="/user/signup" class="btn btn-primary btn-lg">Start Writing Free</a>
            <a href="/user/login"  class="btn btn-ghost  btn-lg">Sign In</a>
        </div>
        <% } %>
    </div>

    <!-- Blog Grid -->
    <% if(blogs.length === 0){ %>

        <div class="empty-state">
            <div class="empty-icon">📝</div>
            <h2 class="empty-title">No posts yet</h2>
            <p class="empty-sub">Be the first to share something great.</p>
            <% if(user){ %>
                <a href="/blog/new" class="btn btn-primary">Write First Post</a>
            <% } else { %>
                <a href="/user/signup" class="btn btn-primary">Get Started</a>
            <% } %>
        </div>

    <% } else { %>

        <h2 class="section-title">Latest Posts</h2>

        <div class="blog-grid">
        <% blogs.forEach(function(blog){ %>

            <article class="blog-card">

                <img
                    class="blog-card-cover"
                    src="<%= blog.coverImageURL %>"
                    alt="<%= blog.title %>"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                >
                <div class="blog-card-cover" style="display:none;background:linear-gradient(135deg,#1e1b4b,#0c4a6e);align-items:center;justify-content:center;font-size:2.5rem;">✍️</div>

                <div class="blog-card-body">
                    <span class="blog-card-tag">Article</span>

                    <a href="/blog/view/<%= blog._id %>" class="blog-card-title">
                        <%= blog.title %>
                    </a>

                    <p class="blog-card-excerpt">
                        <%= blog.body.substring(0, 160) %>…
                    </p>

                    <div class="blog-card-meta">
                        <div class="blog-card-author">
                            <div class="avatar">
                                <%= blog.createdBy.fullName.charAt(0).toUpperCase() %>
                            </div>
                            <span><%= blog.createdBy.fullName %></span>
                        </div>
                        <span><%= new Date(blog.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></span>
                    </div>
                </div>
            </article>

        <% }); %>
        </div>

    <% } %>

</div>
</div>

<!-- Footer -->
<footer style="text-align:center;padding:2.5rem 0;margin-top:4rem;border-top:1px solid var(--border);color:var(--text-3);font-size:.8rem;">
    <span>© <%= new Date().getFullYear() %> BlogApp &nbsp;·&nbsp; Built with ❤️</span>
</footer>

</body>
</html>
